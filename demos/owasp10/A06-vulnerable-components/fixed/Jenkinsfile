// OWASP A06:2021 - Vulnerable and Outdated Components
// Fixed Jenkinsfile: OWASP Dependency-Check runs as a mandatory gate BEFORE
// the build stage. The pipeline fails if any High or Critical CVE is found.

pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Dependency Security Scan') {
            steps {
                // FIX: Scan all Maven dependencies against the NVD CVE database
                // BEFORE building. If a dependency has CVSS >= 7, the build fails here
                // and the vulnerable code never reaches the artifact store or deployment.
                // The NVD API key is stored in Jenkins Credentials (not hard-coded).
                withCredentials([string(credentialsId: 'nvd-api-key', variable: 'NVD_API_KEY')]) {
                    sh '''
                        mvn org.owasp:dependency-check-maven:8.4.3:check \
                            -DfailBuildOnCVSS=7 \
                            -DnvdApiKey=${NVD_API_KEY}
                    '''
                }
            }
            post {
                always {
                    // FIX: Publish the CVE report as a build artifact so developers
                    // can review exactly which CVEs caused a failure.
                    publishHTML(target: [
                        allowMissing: false,
                        reportDir: 'target',
                        reportFiles: 'dependency-check-report.html',
                        reportName: 'OWASP Dependency Check Report'
                    ])
                }
            }
        }

        stage('Build') {
            steps {
                // This stage is only reached if the dependency scan passed.
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('Verify and Deploy') {
            steps {
                // FIX: Generate a SHA-256 checksum of the built artifact and record it.
                // In a production pipeline, compare against a checksum stored in a
                // trusted artifact repository (e.g., Nexus, Artifactory) to detect tampering.
                sh 'sha256sum target/*.jar | tee target/artifact.sha256'

                // FIX: Verify the checksum before deploying
                sh 'sha256sum -c target/artifact.sha256'

                sh 'cp target/*.jar /opt/app/app.jar'
                sh 'systemctl restart app'
            }
        }
    }
}
